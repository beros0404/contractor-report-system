{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "postinstall": "npm install --include=dev && npm run build",
    "seed:activities": "ts-node src/scripts/seed-activities.ts",
    "seed:aportes": "ts-node src/scripts/seed-aportes.ts",
    "seed:evidencias": "ts-node src/scripts/seed-evidencias.ts",
    "seed:all": "npm run seed:activities && npm run seed:aportes && npm run seed:evidencias",
    "test:openai": "ts-node src/test-openai.ts"
  },
  "engines": {
    "node": "18.x"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "assemblyai": "^4.23.1",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.8",
    "mongoose": "^9.2.1",
    "multer": "^2.0.2",
    "openai": "^6.27.0",
    "puppeteer": "^24.37.5"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
